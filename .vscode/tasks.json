{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Maven: compile",
      "type": "shell",
      "command": "${workspaceFolder}/scripts/mvn -q compile",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Maven: test",
      "type": "shell",
      "command": "${workspaceFolder}/scripts/mvn -q test",
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    }
  ]
}
